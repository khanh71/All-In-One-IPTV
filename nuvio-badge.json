{
  "name": "Vietnamese Audio Badges",
  "author": "Nuvio Developer",
  "version": "1.0.0",
  "streamExpressions": [
    {
      "pattern": "(?i)(lồng\\s+tiếng|long\\s+tieng|\\bLT\\b)",
      "type": "badge",
      "properties": {
        "text": "LỒNG TIẾNG",
        "backgroundColor": "#E50914",
        "textColor": "#FFFFFF",
        "style": "filled"
      }
    },
    {
      "pattern": "(?i)(phụ\\s+đề|phu\\s+de|vietsub|\\bsub\\b|\\bPD\\b)",
      "type": "badge",
      "properties": {
        "text": "PHỤ ĐỀ",
        "backgroundColor": "#0084FF",
        "textColor": "#FFFFFF",
        "style": "filled"
      }
    },
    {
      "pattern": "(?i)(thuyết\\s+minH|thuyet\\s+minh|\\bTM\\b)",
      "type": "badge",
      "properties": {
        "text": "THUYẾT MINH",
        "backgroundColor": "#00A859",
        "textColor": "#FFFFFF",
        "style": "filled"
      }
    }
  ]
}